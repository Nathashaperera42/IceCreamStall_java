digraph FlowB {
  rankdir=TB; graph [fontname="Helvetica", fontsize=12, labelloc="t", label="Ordering Flow (Part 2 of 2)", ranksep=0.4, nodesep=0.35];
  node [fontname="Helvetica", fontsize=10, style=filled, fillcolor="#FFF5E9", color="#555555"];
  edge [fontname="Helvetica", fontsize=9];
  A      [shape=circle, fillcolor="#6FC2A6", fontcolor=white, width=0.4, fixedsize=true, label="A"];
  place  [shape=box, label="OrderService.placeOrder():\nassign ID, enqueue,\nstate = NEW"];
  notify1[shape=parallelogram, fillcolor="#BBDEFB", label="Notify observers\n(customer + kitchen)"];
  prep   [shape=box, fillcolor="#C8E6C9", label="Kitchen prepares:\nNEW -> PREPARING -> READY\n(each transition notifies\nobservers - live tracking)"];
  isdeliv[shape=diamond, fillcolor="#FCE1B6", label="Serving =\nDelivery?"];
  ofd    [shape=box, fillcolor="#C8E6C9", label="State -> OUT_FOR_DELIVERY"];
  deliv  [shape=box, fillcolor="#C8E6C9", label="State -> DELIVERED"];
  notify2[shape=parallelogram, fillcolor="#BBDEFB", label="Push live status update\nto tracking screen"];
  feed   [shape=box, label="Customer rates order\n& leaves feedback"];
  store  [shape=box, label="FeedbackService stores\nrating; update average"];
  end    [shape=oval, fillcolor="#6FC2A6", fontcolor=white, label="End"];
  A->place->notify1->prep->isdeliv;
  isdeliv->ofd [label="Yes"];
  isdeliv->deliv [label="No (pickup/dine-in)"];
  ofd->deliv->notify2->feed->store->end;
}
